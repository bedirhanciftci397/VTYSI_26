create database OBS
use OBS
create table bolum(
bolum_id int primary key not null identity(1,1),
bolum_ad nvarchar(50)
);

create table ogr(
ogr_no int primary key not null identity(1,1),
bolum_id int foreign key (bolum_id) references bolum (bolum_id),
ogr_adi nvarchar(50),
ogr_sooyadi nvarchar(50),
adres nvarchar(150)
);

